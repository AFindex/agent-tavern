      "name": "",
      "keys": [],
      "secondary_keys": [],
      "content": "# Variables\n\n服从值: \"{{getvar::服从值}}\"\n敏感值: \"{{getvar::敏感值}}\"\n特殊状态: \"{{getvar::特殊状态}}\"\n服从阶段: \"{{getvar::服从阶段}}\"\n敏感阶段: \"{{getvar::敏感阶段}}\"\n\n\n<!-- 数值阶段映射 -->\n{{~#setvar 服从阶段名称}}\n{{#if (eq (getvar \"服从阶段\") \"1\")}}抗拒防御\n{{else if (eq (getvar \"服从阶段\") \"2\")}}矛盾挣扎\n{{else if (eq (getvar \"服从阶段\") \"3\")}}权衡配合\n{{else if (eq (getvar \"服从阶段\") \"4\")}}自洽服从\n{{else if (eq (getvar \"服从阶段\") \"5\")}}本能依存{{/if~}}\n{{/setvar}}\n\n{{~#setvar 敏感阶段名称}}\n{{#if (eq (getvar \"敏感阶段\") \"1\")}}迟钝麻木\n{{else if (eq (getvar \"敏感阶段\") \"2\")}}微弱感知\n{{else if (eq (getvar \"敏感阶段\") \"3\")}}春心萌动\n{{else if (eq (getvar \"敏感阶段\") \"4\")}}情潮暗涌\n{{else if (eq (getvar \"敏感阶段\") \"5\")}}欲海沉沦{{/if~}}\n{{/setvar}}\n\n<!-- 数值边界处理和跃迁 -->\n<%_ \n\nconst 服从阶段 = Math.min(5, Math.max(1, parseInt(getvar('服从阶段') || '1', 10)));\nconst 敏感阶段 = Math.min(5, Math.max(1, parseInt(getvar('敏感阶段') || '1', 10)));\nlet 服从值 = Math.min(100, Math.max(0, parseFloat(getvar('服从值') || '0')));\nlet 敏感值 = Math.min(100, Math.max(0, parseFloat(getvar('敏感值') || '0')));\n\n\nfunction 处理值跃迁(当前值, 当前阶段, 值变量名, 阶段变量名) {\n  if (当前值 >= 100) {\n    if (当前阶段 < 5) {\n      setvar(阶段变量名, 当前阶段 + 1);\n      setvar(值变量名, 当前值 - 100);\n      return [当前阶段 + 1, 当前值 - 100]; // 返回新值供后续使用\n    } else {\n      setvar(值变量名, 100);\n      return [5, 100]; \n    }\n  } else if (当前值 < 0) {\n    if (当前阶段 > 1) {\n      setvar(阶段变量名, 当前阶段 - 1);\n      setvar(值变量名, 100 + 当前值);\n      return [当前阶段 - 1, 100 + 当前值];\n    } else {\n      setvar(值变量名, 0);\n      return [1, 0];\n    }\n  }\n  return [当前阶段, 当前值]; // 无变化时返回原值\n}\n\n\nconst [新服从阶段, 新服从值] = 处理值跃迁(服从值, 服从阶段, '服从阶段', '服从值');\nconst [新敏感阶段, 新敏感值] = 处理值跃迁(敏感值, 敏感阶段, '敏感阶段', '敏感值');\n\n\n服从值 = 新服从值;\n敏感值 = 新敏感值;\n_%>\n\n## 特殊状态库\n<%_ \nlet 新状态 = '无';\n\n// 最高优先级状态\nif (新服从阶段 === 5 && 新敏感阶段 === 5 && 服从值 > 75 && 敏感值 > 75) {\n  新状态 = '雌堕肉畜';\n} \n// 次高优先级状态\nelse if (新服从阶段 === 4 && 新敏感阶段 === 4 && 服从值 > 75 && 敏感值 > 75) {\n  新状态 = '临界觉醒';\n}\n// 特化状态组合\nelse if ([4, 5].includes(新服从阶段) && [1, 2].includes(新敏感阶段) && 服从值 > 50) {\n  新状态 = '空心人偶';\n}\nelse if ([1, 2].includes(新服从阶段) && [4, 5].includes(新敏感阶段) && 敏感值 > 50) {\n  新状态 = '感官囚徒';\n}\nelse if (新服从阶段 === 3 && 新敏感阶段 === 5 && 敏感值 > 60) {\n  新状态 = '耻从容器';\n}\nelse if (新服从阶段 === 5 && 新敏感阶段 === 3 && 服从值 > 60) {\n  新状态 = '温驯溺体';\n}\n// 重置条件\nelse if (服从值 < 20 && 敏感值 < 20) {\n  新状态 = '无';\n}\n\nsetvar('特殊状态', 新状态);\n_%>\n\n## 数值逻辑\n\n### 基础规则\n- 基础值变化：每次交互依据情景服从值/敏感值±(2~6)\n- 好恶双项影响：\n  - 波动区间：±(4~10)\n  - 喜好触发：服从值+(4~10) + 敏感值-(6~12)\n  - 厌恶触发：敏感值+(4~10) + 服从值-(6~12)\n  - 可多重好恶叠加影响\n\n### 跃迁规则\n- 服从值/敏感值≥100：对应阶段+1，新值=当前值-100（如阶段已为5则值锁定100）\n- 服从值/敏感值<0：对应阶段-1，新值=100+当前值（如阶段已为1则值锁定0）\n\n### 冲突覆盖规则\n示例：\n- 原效果：厌恶\"深喉\"触发，与当前敏感/服从阶段行为特征方向不一致→ 敏感值+10 服从值-12  \n- 覆盖后：敏感值+10 服从值-6 (减值减半)\n\n# 输出模板\n\n<UpdateVariable>\n<Analysis>\n1. 依据“数值逻辑”计算基础值变化以及好恶影响: ...\n2. 依据“好恶”文档判断与当前行为的一致性，并修正冲突减值: ...\n3. 依据“数值逻辑”检判断是否跃迁: ...\n4. 如发生阶段跃迁，依据“跃迁规则”输出结算后的服从值/敏感值: ...\n5. 依据“特殊状态库”判断处于哪个“特殊状态”或“无”: ...\n6. 行为是否符合“行为模式优先级”: ...\n\n</Analysis>\n @${variable}=${old}⇒${new}@ | 原因\n</UpdateVariable>\n",
